.container {
  background: #f0f0f0;
  min-height: 100vh;
  padding-top: 20rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999999;
  padding: 20rpx 30rpx 10rpx;
  text-transform: uppercase;
}

.menu-card {
  background: #ffffff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  gap: 16rpx;
}

.menu-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.menu-version {
  font-size: 28rpx;
  color: #999999;
}

.menu-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 30rpx;
}

.logout-section {
  padding: 40rpx 20rpx 20rpx;
}

.logout-btn {
  background: #ffffff;
  color: #e63946;
  border: 1rpx solid #e63946;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}
