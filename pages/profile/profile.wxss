/* 个人信息页样式 */
.container {
  background: #f0f0f0;
  min-height: 100vh;
}

/* 顶部个人信息 */
.profile-header {
  background: linear-gradient(160deg, #1a1a1a 0%, #3d0000 100%);
  padding: 50rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-circle {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #c0392b, #e74c3c);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(243, 156, 18, 0.6);
  box-shadow: 0 8rpx 24rpx rgba(192, 57, 43, 0.5);
}

.avatar-char {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: bold;
}

.belt-badge-wrap {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: #f4a261;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
  border: 2rpx solid #ffffff;
}

.belt-level {
  font-size: 18rpx;
  color: #1a1a2e;
  font-weight: bold;
}

.member-type-expiry {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.belt-text {
  color: #f4a261;
  font-weight: bold;
}

.user-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.member-level {
  font-size: 26rpx;
  color: #f39c12;
  margin-bottom: 8rpx;
}

.join-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 数据概览卡片 */
.stats-card {
  background: #ffffff;
  margin: -20rpx 20rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.stat-num.gold {
  color: #e67e22;
}

.stat-num.red {
  color: #c0392b;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 信息卡片 */
.info-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.info-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  padding: 24rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
}

.gold-text {
  color: #e67e22;
  font-weight: bold;
}

.red-text {
  color: #c0392b;
  font-weight: bold;
}

.info-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 24rpx;
}

/* 进度条 */
.progress-section {
  padding: 16rpx 24rpx 24rpx;
}

.progress-bar-track {
  background: #e0e0e0;
  border-radius: 8rpx;
  height: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #c0392b, #f39c12);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
}

.pl-used {
  font-size: 22rpx;
  color: #c0392b;
}

.pl-remain {
  font-size: 22rpx;
  color: #999999;
}

/* 功能菜单 */
.menu-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.menu-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 24rpx;
}

/* 退出登录 */
.logout-section {
  padding: 0 20rpx 20rpx;
}

.logout-btn {
  width: 100%;
  background: #ffffff;
  color: #c0392b;
  border: 2rpx solid #c0392b;
  border-radius: 50rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 2rpx 8rpx rgba(192, 57, 43, 0.2);
}

.logout-btn::after {
  border: none;
}
