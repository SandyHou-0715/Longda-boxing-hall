.container {
  background: #f0f0f0;
  min-height: 100vh;
}

.about-hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #e63946 100%);
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hero-icon {
  font-size: 80rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 4rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.9;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.contact-right {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.contact-value {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  position: relative;
}

.timeline-year {
  font-size: 26rpx;
  font-weight: bold;
  color: #e63946;
  width: 80rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #cccccc;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.timeline-dot.active {
  background: #e63946;
}

.timeline-desc {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
}

.env-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.env-photo {
  width: calc(50% - 8rpx);
  height: 180rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  padding: 16rpx;
}

.env-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
}
