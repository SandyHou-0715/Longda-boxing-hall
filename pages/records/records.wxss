.container {
  background: #f0f0f0;
  min-height: 100vh;
}

.summary-bar {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 30rpx;
  text-align: center;
}

.summary-text {
  font-size: 30rpx;
  color: #f4a261;
  font-weight: bold;
}

.month-group {
  margin: 20rpx 20rpx 0;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 4rpx;
}

.month-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.month-count {
  font-size: 24rpx;
  color: #999999;
}

.record-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  width: 120rpx;
  flex-shrink: 0;
  text-align: center;
}

.record-date {
  display: block;
  font-size: 22rpx;
  color: #555555;
  margin-bottom: 4rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.record-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.record-right {
  flex: 1;
}

.record-course {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.record-meta {
  font-size: 22rpx;
  color: #999999;
}

.record-status {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.tag-done {
  font-size: 20rpx;
  background: #e8f5e9;
  color: #2e7d32;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
