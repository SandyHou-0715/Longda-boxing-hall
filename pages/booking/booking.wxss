/* 预约课程页样式 */
.container {
  background: #f0f0f0;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #1a1a1a, #3d0000);
  padding: 30rpx 30rpx 40rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 剩余课时提示条 */
.remaining-bar {
  background: linear-gradient(90deg, #c0392b, #e74c3c);
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remaining-icon {
  font-size: 32rpx;
}

.remaining-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.remaining-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 列表容器 */
.list-container {
  padding: 20rpx;
}

/* 课程卡片 */
.course-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #c0392b;
}

.course-card.booked {
  border-left-color: #2e7d32;
  opacity: 0.85;
}

/* 课程头部 */
.course-header {
  padding: 24rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.course-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

/* 已预约标记 */
.booked-badge {
  background: #e8f5e9;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  flex-shrink: 0;
}

.booked-text {
  font-size: 22rpx;
  color: #2e7d32;
  font-weight: bold;
}

/* 课程详情 */
.course-details {
  padding: 20rpx 24rpx;
  background: #fafafa;
  margin: 16rpx 0 0;
}

.detail-row {
  display: flex;
  gap: 30rpx;
  margin-bottom: 10rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-item {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
}

.seats-info {
  color: #666666;
}

.seats-low {
  color: #e74c3c;
  font-weight: bold;
}

/* 课程描述 */
.course-desc {
  font-size: 24rpx;
  color: #999999;
  padding: 16rpx 24rpx;
  line-height: 1.6;
  display: block;
}

/* 操作按钮区域 */
.action-row {
  padding: 0 24rpx 24rpx;
  display: flex;
  justify-content: flex-end;
}

.book-btn {
  background: linear-gradient(90deg, #c0392b, #e74c3c);
  color: #ffffff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(192, 57, 43, 0.35);
}

.cancel-book-btn {
  background: transparent;
  color: #999999;
  padding: 14rpx 48rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 1rpx solid #e0e0e0;
}

.full-btn {
  background: #f5f5f5;
  color: #999999;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.no-class-btn {
  background: #fff8e1;
  color: #f57f17;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 1rpx solid #ffe082;
}

/* 难度标签 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.tag-beginner {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-intermediate {
  background: #fff8e1;
  color: #f57f17;
}

.tag-advanced {
  background: #fce4ec;
  color: #c62828;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
