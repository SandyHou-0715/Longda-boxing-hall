.container {
  background: #f0f0f0;
  min-height: 100vh;
}

.coach-hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx 30rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hero-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e63946, #c1121f);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(244, 162, 97, 0.6);
}

.hero-avatar-text {
  font-size: 64rpx;
  color: #ffffff;
  font-weight: bold;
}

.hero-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.hero-specialty {
  font-size: 28rpx;
  color: #f4a261;
}

.hero-stats {
  display: flex;
  gap: 50rpx;
  margin: 8rpx 0;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.hero-stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.hero-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.level-badge {
  background: rgba(244, 162, 97, 0.2);
  border: 1rpx solid rgba(244, 162, 97, 0.5);
  border-radius: 24rpx;
  padding: 6rpx 24rpx;
}

.level-text {
  font-size: 24rpx;
  color: #f4a261;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.bio-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
}

.honor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.honor-item:last-child {
  border-bottom: none;
}

.honor-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.honor-text {
  font-size: 28rpx;
  color: #333333;
}

.courses-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.course-icon {
  font-size: 32rpx;
}

.course-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
