/* 商品详情页样式 */
.container {
  background: linear-gradient(160deg, #0d0d0d 0%, #1c1c1e 100%);
  min-height: 100vh;
}

.product-banner {
  width: 100%;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.banner-icon {
  font-size: 160rpx;
}

.banner-overlay {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
}

.category-badge {
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.info-card, .detail-card, .quantity-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin: 16rpx 20rpx 0;
  padding: 24rpx;
}

.product-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff2d55;
}

.original-price {
  font-size: 26rpx;
  color: #8e8e93;
  text-decoration: line-through;
}

.discount-badge {
  background: rgba(255, 45, 85, 0.15);
  border: 1rpx solid rgba(255, 45, 85, 0.3);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.discount-text {
  font-size: 20rpx;
  color: #ff2d55;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stats-text {
  font-size: 22rpx;
  color: #8e8e93;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.feature-icon {
  font-size: 22rpx;
  color: #30d158;
}

.feature-text {
  font-size: 24rpx;
  color: #8e8e93;
}

.quantity-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quantity-label {
  font-size: 28rpx;
  color: #ffffff;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn.add {
  background: rgba(255, 45, 85, 0.2);
  border-color: rgba(255, 45, 85, 0.4);
}

.qty-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.qty-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  min-width: 40rpx;
  text-align: center;
}

.subtotal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 20rpx 0;
  padding: 16rpx 24rpx;
}

.subtotal-label {
  font-size: 26rpx;
  color: #8e8e93;
}

.subtotal-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff2d55;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(13, 13, 13, 0.95);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.cart-count-area {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon-btn {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #ff2d55;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-num {
  font-size: 16rpx;
  color: #ffffff;
  font-weight: bold;
}

.add-cart-btn {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 45, 85, 0.4);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-cart-text {
  font-size: 28rpx;
  color: #ff2d55;
  font-weight: bold;
}

.buy-now-btn {
  flex: 1.2;
  height: 80rpx;
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 45, 85, 0.4);
}

.buy-now-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8e8e93;
}
