<view class="container">
  <view class="coach-card" wx:for="{{coaches}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
    <view class="coach-top">
      <view class="avatar-circle">
        <text class="avatar-text">{{item.avatar}}</text>
      </view>
      <view class="coach-info">
        <view class="coach-name-row">
          <text class="coach-name">{{item.name}}</text>
          <text class="coach-level">{{item.level}}</text>
        </view>
        <text class="coach-specialty">专项：{{item.specialty}}</text>
        <text class="coach-years">从教 {{item.years}} 年 · 学员 {{item.students}} 人</text>
      </view>
      <view class="coach-rating">
        <text class="rating-num">{{item.rating}}</text>
        <text class="rating-star">⭐</text>
      </view>
    </view>
    <view class="coach-courses">
      <text class="course-tag" wx:for="{{item.courses}}" wx:key="*this" wx:for-item="course">{{course}}</text>
    </view>
  </view>
  <view style="height: 40rpx;"></view>
</view>
