/* 商城页样式 */
.container {
  background: linear-gradient(160deg, #0d0d0d 0%, #1c1c1e 100%);
  min-height: 100vh;
}

/* 顶部搜索栏 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #0d0d0d;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  padding: 0 24rpx;
  height: 72rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #ffffff;
  height: 72rpx;
  line-height: 72rpx;
}

.search-placeholder {
  color: #8e8e93;
}

.cart-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  flex-shrink: 0;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #ff2d55;
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-badge-text {
  font-size: 18rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 分类导航 */
.category-bar {
  white-space: nowrap;
  padding: 0 16rpx 16rpx;
  background: #0d0d0d;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin: 0 8rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.category-item.active {
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(255, 45, 85, 0.3);
}

.category-text {
  font-size: 26rpx;
  color: #8e8e93;
}

.category-item.active .category-text {
  color: #ffffff;
  font-weight: bold;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx;
  gap: 16rpx;
}

.product-card {
  width: calc(50% - 8rpx);
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  overflow: hidden;
}

/* 商品封面 */
.product-cover {
  width: 100%;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.product-cover-icon {
  font-size: 80rpx;
}

.product-category-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.category-tag-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 商品信息 */
.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff2d55;
}

.original-price {
  font-size: 22rpx;
  color: #8e8e93;
  text-decoration: line-through;
}

.sales-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sales-text {
  font-size: 20rpx;
  color: #8e8e93;
}

.add-cart-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.3);
}

.add-cart-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8e8e93;
}
