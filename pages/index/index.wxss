/* 首页样式 */
.container {
  background: #f0f0f0;
  min-height: 100vh;
}

/* 顶部头部区域 */
.index-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx 30rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 20rpx;
}

.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #e63946, #c1121f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 3rpx solid rgba(244, 162, 97, 0.6);
}

.avatar-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.welcome-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.member-badge {
  font-size: 22rpx;
  color: #f4a261;
  display: block;
}

.today-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

/* 轮播图 */
.banner-swiper {
  height: 280rpx;
  margin-bottom: 0;
}

.banner-slide {
  height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* 公告栏 */
.notice-bar {
  background: #fff8e1;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  border-bottom: 1rpx solid #ffe082;
}

.notice-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-scroll {
  flex: 1;
  white-space: nowrap;
}

.notice-text {
  font-size: 26rpx;
  color: #795548;
}

/* 数据概览 */
.stats-row {
  display: flex;
  margin: 20rpx 20rpx 0;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border-top: 6rpx solid #1a1a2e;
}

.stat-card.gold {
  border-top-color: #f4a261;
}

.stat-card.red {
  border-top-color: #e63946;
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

/* 卡片通用 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title-row {
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.card-link {
  font-size: 24rpx;
  color: #e63946;
}

/* 快捷入口 - 6 items, 2 rows of 3 */
.quick-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx 0;
}

.nav-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.nav-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.red-bg {
  background: linear-gradient(135deg, #e63946, #c1121f);
}

.green-bg {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
}

.gold-bg {
  background: linear-gradient(135deg, #e67e22, #f4a261);
}

.blue-bg {
  background: linear-gradient(135deg, #1565c0, #1e88e5);
}

.purple-bg {
  background: linear-gradient(135deg, #6a0dad, #9b59b6);
}

.dark-bg {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}

.gray-bg {
  background: linear-gradient(135deg, #546e7a, #78909c);
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 24rpx;
  color: #666666;
}

/* 近期课程列表 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-left {
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.schedule-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
}

.schedule-day {
  font-size: 20rpx;
  color: #999999;
}

.schedule-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.schedule-right {
  flex: 1;
}

.schedule-course {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
}

.schedule-meta {
  font-size: 22rpx;
  color: #999999;
}

.schedule-status {
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 教练预览 */
.coaches-preview {
  display: flex;
  flex-direction: row;
  gap: 30rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.coach-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.coach-avatar-circle {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e, #e63946);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coach-avatar-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.coach-name-text {
  font-size: 22rpx;
  color: #555555;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

/* 标签 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.tag-pending {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-completed {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-cancelled {
  background: #f5f5f5;
  color: #757575;
}
