/* 首页样式 */
.container {
  background: #f0f0f0;
  min-height: 100vh;
}

/* 顶部横幅 */
.banner {
  background: linear-gradient(135deg, #1a1a1a 0%, #3d0000 100%);
  padding: 40rpx 30rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #c0392b, #e74c3c);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 3rpx solid rgba(243, 156, 18, 0.6);
}

.avatar-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.welcome-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.level-badge {
  display: inline-block;
  background: rgba(243, 156, 18, 0.2);
  border: 1rpx solid rgba(243, 156, 18, 0.5);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.level-text {
  font-size: 22rpx;
  color: #f39c12;
}

.banner-right {
  flex-shrink: 0;
}

.date-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 数据概览卡片 */
.stats-row {
  display: flex;
  margin: -20rpx 20rpx 0;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border-top: 6rpx solid #1a1a1a;
}

.stat-card.gold {
  border-top-color: #f39c12;
}

.stat-card.red {
  border-top-color: #c0392b;
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

/* 卡片通用 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.card-link {
  font-size: 24rpx;
  color: #c0392b;
}

/* 套餐进度 */
.package-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.package-expire {
  font-size: 22rpx;
  color: #999999;
}

.progress-section {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-used {
  font-size: 24rpx;
  color: #666666;
}

.progress-total {
  font-size: 24rpx;
  color: #999999;
}

.progress-bar-track {
  background: #e0e0e0;
  border-radius: 8rpx;
  height: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #c0392b, #f39c12);
}

.progress-remain {
  font-size: 24rpx;
  color: #c0392b;
  font-weight: bold;
}

/* 近期课程列表 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-left {
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.schedule-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
}

.schedule-day {
  font-size: 20rpx;
  color: #999999;
}

.schedule-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.schedule-right {
  flex: 1;
}

.schedule-course {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.schedule-meta {
  font-size: 22rpx;
  color: #999999;
}

.schedule-status {
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

/* 标签 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.tag-pending {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-completed {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-cancelled {
  background: #f5f5f5;
  color: #757575;
}

/* 快捷入口 */
.quick-nav {
  display: flex;
  justify-content: space-around;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.nav-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.red-bg {
  background: linear-gradient(135deg, #c0392b, #e74c3c);
}

.dark-bg {
  background: linear-gradient(135deg, #1a1a1a, #333333);
}

.gold-bg {
  background: linear-gradient(135deg, #e67e22, #f39c12);
}

.gray-bg {
  background: linear-gradient(135deg, #546e7a, #78909c);
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 24rpx;
  color: #666666;
}
