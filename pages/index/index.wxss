/* 首页样式 - 暗黑酷炫风 */
.container {
  background: linear-gradient(160deg, #0d0d0d 0%, #1c1c1e 100%);
  min-height: 100vh;
}

/* 顶部头部区域 */
.index-header {
  background: linear-gradient(135deg, #0d0d0d 0%, #1c1c1e 100%);
  padding: 40rpx 30rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 20rpx;
}

.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #ff2d55, #5856d6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 20rpx rgba(255, 45, 85, 0.4);
}

.avatar-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.welcome-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.member-badge {
  font-size: 22rpx;
  color: #ffd60a;
  display: block;
}

.header-right {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 30rpx;
  padding: 8rpx 16rpx;
  gap: 6rpx;
  flex-shrink: 0;
  max-width: 220rpx;
}

.campus-name-text {
  font-size: 20rpx;
  color: #8e8e93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-switch-icon {
  font-size: 22rpx;
  color: #8e8e93;
}

/* 轮播图 */
.banner-swiper {
  height: 280rpx;
  margin-bottom: 0;
}

.banner-slide {
  height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.4);
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* 公告栏 */
.notice-bar {
  background: rgba(255, 214, 10, 0.08);
  border-bottom: 1rpx solid rgba(255, 214, 10, 0.15);
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
}

.notice-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-scroll {
  flex: 1;
  white-space: nowrap;
}

.notice-text {
  font-size: 24rpx;
  color: #ffd60a;
}

/* 当前校区卡片 */
.campus-card {
  margin: 20rpx 20rpx 0;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.campus-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.campus-icon-big {
  font-size: 44rpx;
  flex-shrink: 0;
}

.campus-card-info {
  flex: 1;
  min-width: 0;
}

.campus-card-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-card-addr {
  font-size: 20rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-card-hours {
  font-size: 20rpx;
  color: #30d158;
  display: block;
}

.campus-switch-btn {
  font-size: 22rpx;
  color: #ff2d55;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 数据概览 */
.stats-row {
  display: flex;
  margin: 20rpx 20rpx 0;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  border-top: 4rpx solid #007aff;
}

.stat-card.gold {
  border-top-color: #ffd60a;
}

.stat-card.red {
  border-top-color: #ff2d55;
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #8e8e93;
}

/* 卡片通用 */
.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.card-link {
  font-size: 24rpx;
  color: #ff2d55;
}

/* 近期课程列表 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-left {
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.schedule-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.schedule-day {
  font-size: 20rpx;
  color: #8e8e93;
}

.schedule-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 20rpx;
  flex-shrink: 0;
}

.schedule-right {
  flex: 1;
}

.schedule-course {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 6rpx;
}

.schedule-meta {
  font-size: 22rpx;
  color: #8e8e93;
}

.schedule-status {
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 教练预览 */
.coaches-preview {
  display: flex;
  flex-direction: row;
  gap: 30rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.coach-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.coach-avatar-circle {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ff2d55, #5856d6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(255, 45, 85, 0.3);
}

.coach-avatar-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.coach-name-text {
  font-size: 22rpx;
  color: #8e8e93;
}

/* 会员卡区域标题 */
.section-title-row {
  margin: 30rpx 20rpx 0;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 6rpx;
}

.section-sub {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 会员卡模块 */
.member-card-section {
  margin: 20rpx 0 0;
  padding-left: 20rpx;
}

.member-card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.member-card-type-icon {
  font-size: 32rpx;
}

.member-card-type-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 套餐卡片轮播 */
.card-swiper {
  height: 220rpx;
}

.pack-card {
  height: 210rpx;
  background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
  border: 1rpx solid rgba(255, 45, 85, 0.3);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-right: 20rpx;
  box-shadow: 0 0 15rpx rgba(255, 45, 85, 0.1);
}

.pack-card.monthly {
  border-color: rgba(0, 122, 255, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 122, 255, 0.1);
}

.pack-card.yearly {
  border-color: rgba(255, 214, 10, 0.4);
  box-shadow: 0 0 20rpx rgba(255, 214, 10, 0.15);
}

.pack-card-top {
  flex: 1;
}

.pack-tag {
  font-size: 18rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  display: inline-block;
  margin-bottom: 10rpx;
}

.pack-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.pack-price-row {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.pack-price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff2d55;
  line-height: 1;
}

.pack-times {
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: 4rpx;
}

.pack-card-bottom {
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding-top: 12rpx;
}

.pack-validity {
  font-size: 20rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 6rpx;
}

.pack-highlight {
  font-size: 20rpx;
  color: #ffd60a;
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #8e8e93;
}

/* 标签 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.tag-pending {
  background: rgba(0, 122, 255, 0.15);
  color: #007aff;
}

.tag-completed {
  background: rgba(48, 209, 88, 0.15);
  color: #30d158;
}

.tag-cancelled {
  background: rgba(142, 142, 147, 0.15);
  color: #8e8e93;
}
