<view class="container">
  <!-- 顶部头部区域 -->
  <view class="index-header">
    <view class="header-left">
      <view class="avatar-circle">
        <text class="avatar-text">{{userInfo.avatar}}</text>
      </view>
      <view>
        <text class="welcome-text">你好，{{userInfo.name}} 👋</text>
        <text class="member-badge">{{userInfo.memberLevel}} · {{userInfo.belt}}</text>
      </view>
    </view>
    <text class="today-text">{{todayStr}}</text>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" circular="{{true}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-slide" style="background:{{item.color}}">
        <text class="banner-title">{{item.title}}</text>
        <text class="banner-subtitle">{{item.subtitle}}</text>
      </view>
    </swiper-item>
  </swiper>

  <!-- 公告栏 -->
  <view class="notice-bar">
    <text class="notice-icon">📢</text>
    <scroll-view scroll-x="{{false}}" class="notice-scroll">
      <text class="notice-text">{{currentAnnouncement}}</text>
    </scroll-view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goToSchedule">
      <text class="stat-number">{{remainingClasses}}</text>
      <text class="stat-label">剩余课时</text>
    </view>
    <view class="stat-card gold" bindtap="goToPoints">
      <text class="stat-number">{{userInfo.points}}</text>
      <text class="stat-label">我的积分</text>
    </view>
    <view class="stat-card red" bindtap="goToCheckin">
      <text class="stat-number">{{consecutiveCheckIn}}</text>
      <text class="stat-label">连续签到</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="card-title-row">
      <text class="card-title">快捷功能</text>
    </view>
    <view class="quick-nav">
      <view class="nav-item" bindtap="goToBooking">
        <view class="nav-icon-box red-bg"><text class="nav-icon">📋</text></view>
        <text class="nav-label">约课</text>
      </view>
      <view class="nav-item" bindtap="goToCheckin">
        <view class="nav-icon-box green-bg"><text class="nav-icon">✅</text></view>
        <text class="nav-label">签到</text>
      </view>
      <view class="nav-item" bindtap="goToPoints">
        <view class="nav-icon-box gold-bg"><text class="nav-icon">⭐</text></view>
        <text class="nav-label">积分</text>
      </view>
      <view class="nav-item" bindtap="goToCoaches">
        <view class="nav-icon-box blue-bg"><text class="nav-icon">👊</text></view>
        <text class="nav-label">教练</text>
      </view>
      <view class="nav-item" bindtap="goToRecords">
        <view class="nav-icon-box purple-bg"><text class="nav-icon">📚</text></view>
        <text class="nav-label">记录</text>
      </view>
      <view class="nav-item" bindtap="goToMemberCard">
        <view class="nav-icon-box dark-bg"><text class="nav-icon">💳</text></view>
        <text class="nav-label">会员卡</text>
      </view>
    </view>
  </view>

  <!-- 近期课程 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">近期课程</text>
      <text class="card-link" bindtap="goToSchedule">查看全部 ›</text>
    </view>
    <block wx:if="{{recentSchedule.length > 0}}">
      <view class="schedule-item" wx:for="{{recentSchedule}}" wx:key="id">
        <view class="schedule-left">
          <text class="schedule-date">{{item.dateDisplay}}</text>
          <text class="schedule-day">{{item.dayOfWeek}}</text>
        </view>
        <view class="schedule-divider"></view>
        <view class="schedule-right">
          <text class="schedule-course">{{item.courseName}}</text>
          <text class="schedule-meta">{{item.time}} · {{item.coach}} · {{item.location}}</text>
        </view>
        <view class="schedule-status">
          <text class="tag {{item.statusClass}}">{{item.status}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text class="empty-icon">📅</text>
      <text class="empty-text">暂无近期课程，去预约吧</text>
    </view>
  </view>

  <!-- 教练团队入口 -->
  <view class="card" bindtap="goToCoaches">
    <view class="card-header">
      <text class="card-title">教练团队</text>
      <text class="card-link">查看全部 ›</text>
    </view>
    <view class="coaches-preview">
      <view class="coach-avatar" wx:for="{{coachPreview}}" wx:key="id">
        <view class="coach-avatar-circle"><text class="coach-avatar-text">{{item.avatar}}</text></view>
        <text class="coach-name-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>
