<view class="container">
  <!-- 顶部头部区域 -->
  <view class="index-header">
    <view class="header-left">
      <view class="avatar-circle">
        <text class="avatar-text">{{userInfo.avatar}}</text>
      </view>
      <view>
        <text class="welcome-text">你好，{{userInfo.name}} 👋</text>
        <text class="member-badge">{{userInfo.memberLevel}} · {{userInfo.belt}}</text>
      </view>
    </view>
    <view class="header-right" bindtap="switchCampus">
      <text class="campus-name-text">{{currentCampus.name}}</text>
      <text class="campus-switch-icon">⌄</text>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" circular="{{true}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-slide" style="background:{{item.color}}">
        <text class="banner-title">{{item.title}}</text>
        <text class="banner-subtitle">{{item.subtitle}}</text>
      </view>
    </swiper-item>
  </swiper>

  <!-- 公告栏 -->
  <view class="notice-bar">
    <text class="notice-icon">📢</text>
    <scroll-view scroll-x="{{false}}" class="notice-scroll">
      <text class="notice-text">{{currentAnnouncement}}</text>
    </scroll-view>
  </view>

  <!-- 当前校区信息 -->
  <view class="campus-card" bindtap="switchCampus">
    <view class="campus-card-left">
      <text class="campus-icon-big">🏟</text>
      <view class="campus-card-info">
        <text class="campus-card-name">{{currentCampus.name}}</text>
        <text class="campus-card-addr">{{currentCampus.address}}</text>
        <text class="campus-card-hours">营业时间：{{currentCampus.hours}}</text>
      </view>
    </view>
    <text class="campus-switch-btn">切换 ›</text>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goToSchedule">
      <text class="stat-number">{{remainingClasses}}</text>
      <text class="stat-label">剩余课时</text>
    </view>
    <view class="stat-card gold" bindtap="goToPoints">
      <text class="stat-number">{{userInfo.points}}</text>
      <text class="stat-label">我的积分</text>
    </view>
    <view class="stat-card red" bindtap="goToCheckin">
      <text class="stat-number">{{consecutiveCheckIn}}</text>
      <text class="stat-label">连续签到</text>
    </view>
  </view>

  <!-- 近期课程 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">近期课程</text>
      <text class="card-link" bindtap="goToSchedule">查看全部 ›</text>
    </view>
    <block wx:if="{{recentSchedule.length > 0}}">
      <view class="schedule-item" wx:for="{{recentSchedule}}" wx:key="id">
        <view class="schedule-left">
          <text class="schedule-date">{{item.dateDisplay}}</text>
          <text class="schedule-day">{{item.dayOfWeek}}</text>
        </view>
        <view class="schedule-divider"></view>
        <view class="schedule-right">
          <text class="schedule-course">{{item.courseName}}</text>
          <text class="schedule-meta">{{item.time}} · {{item.coach}} · {{item.location}}</text>
        </view>
        <view class="schedule-status">
          <text class="tag {{item.statusClass}}">{{item.status}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text class="empty-icon">📅</text>
      <text class="empty-text">暂无近期课程，去预约吧</text>
    </view>
  </view>

  <!-- 教练团队 -->
  <view class="card" bindtap="goToCoaches">
    <view class="card-header">
      <text class="card-title">教练团队</text>
      <text class="card-link">查看全部 ›</text>
    </view>
    <view class="coaches-preview">
      <view class="coach-avatar" wx:for="{{coachPreview}}" wx:key="id">
        <view class="coach-avatar-circle"><text class="coach-avatar-text">{{item.avatar}}</text></view>
        <text class="coach-name-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 会员卡购买模块 -->
  <view class="section-title-row">
    <text class="section-title">会员卡套餐</text>
    <text class="section-sub">选择适合你的训练计划</text>
  </view>

  <!-- 次卡套餐 -->
  <view class="member-card-section">
    <view class="member-card-header">
      <text class="member-card-type-icon">🎫</text>
      <text class="member-card-type-name">次卡套餐</text>
    </view>
    <swiper class="card-swiper" display-multiple-items="{{1}}" next-margin="60rpx">
      <swiper-item wx:for="{{memberCards.classPack}}" wx:key="id">
        <view class="pack-card" bindtap="goToCardDetail" data-type="classPack" data-id="{{item.id}}">
          <view class="pack-card-top">
            <text class="pack-tag" style="color:{{item.tagColor}}; border-color:{{item.tagColor}}">{{item.tag}}</text>
            <text class="pack-name">{{item.name}}</text>
            <view class="pack-price-row">
              <text class="pack-price">¥{{item.price}}</text>
              <text class="pack-times">{{item.times}}次</text>
            </view>
          </view>
          <view class="pack-card-bottom">
            <text class="pack-validity">{{item.validity}}</text>
            <text class="pack-highlight">🎁 {{item.highlight}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 月卡套餐 -->
  <view class="member-card-section">
    <view class="member-card-header">
      <text class="member-card-type-icon">📅</text>
      <text class="member-card-type-name">月卡套餐</text>
    </view>
    <swiper class="card-swiper" display-multiple-items="{{1}}" next-margin="60rpx">
      <swiper-item wx:for="{{memberCards.monthly}}" wx:key="id">
        <view class="pack-card monthly" bindtap="goToCardDetail" data-type="monthly" data-id="{{item.id}}">
          <view class="pack-card-top">
            <text class="pack-tag" style="color:{{item.tagColor}}; border-color:{{item.tagColor}}">{{item.tag}}</text>
            <text class="pack-name">{{item.name}}</text>
            <view class="pack-price-row">
              <text class="pack-price">¥{{item.price}}</text>
              <text class="pack-times">{{item.unit}}</text>
            </view>
          </view>
          <view class="pack-card-bottom">
            <text class="pack-validity">{{item.suitable}}</text>
            <text class="pack-highlight">🎁 {{item.highlight}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 年卡套餐 -->
  <view class="member-card-section">
    <view class="member-card-header">
      <text class="member-card-type-icon">👑</text>
      <text class="member-card-type-name">年卡套餐</text>
    </view>
    <swiper class="card-swiper" display-multiple-items="{{1}}" next-margin="60rpx">
      <swiper-item wx:for="{{memberCards.yearly}}" wx:key="id">
        <view class="pack-card yearly" bindtap="goToCardDetail" data-type="yearly" data-id="{{item.id}}">
          <view class="pack-card-top">
            <text class="pack-tag" style="color:{{item.tagColor}}; border-color:{{item.tagColor}}">{{item.tag}}</text>
            <text class="pack-name">{{item.name}}</text>
            <view class="pack-price-row">
              <text class="pack-price">¥{{item.price}}</text>
              <text class="pack-times">{{item.unit}}</text>
            </view>
          </view>
          <view class="pack-card-bottom">
            <text class="pack-validity">折算 {{item.monthlyAvg}}</text>
            <text class="pack-highlight" wx:if="{{item.benefits && item.benefits.length > 0}}">🎁 {{item.benefits[0]}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view style="height: 40rpx;"></view>
</view>
