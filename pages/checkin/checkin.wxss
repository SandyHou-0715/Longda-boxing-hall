.container {
  background: #f0f0f0;
  min-height: 100vh;
}

.checkin-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx 30rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.today-date {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

.streak-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.streak-num {
  font-size: 56rpx;
  font-weight: bold;
  color: #f4a261;
}

.streak-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.checkin-btn-wrap {
  display: flex;
  justify-content: center;
  margin: -30rpx 30rpx 0;
}

.checkin-btn {
  width: 100%;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.btn-active {
  background: linear-gradient(135deg, #e63946, #c1121f);
}

.btn-done {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
}

.checkin-btn-icon {
  font-size: 80rpx;
}

.checkin-btn-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
}

.checkin-btn-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 24rpx 20rpx 0;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title-row {
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.week-header {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12rpx;
}

.week-day {
  font-size: 24rpx;
  color: #999999;
  width: 72rpx;
  text-align: center;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
  min-height: 72rpx;
  justify-content: center;
  border-radius: 8rpx;
}

.cal-cell.empty {
  opacity: 0;
}

.cal-cell.today .cal-date {
  color: #e63946;
  font-weight: bold;
}

.cal-cell.checked {
  background: rgba(46, 125, 50, 0.1);
}

.cal-date {
  font-size: 26rpx;
  color: #333333;
}

.cal-dot {
  font-size: 16rpx;
  color: #2d6a4f;
  line-height: 1;
}

.reward-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.reward-item:last-child {
  border-bottom: none;
}

.reward-days-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #cccccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.reward-days-circle.reached {
  border-color: #f4a261;
  background: #fff8e1;
}

.reward-days-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.2;
}

.reward-days-unit {
  font-size: 18rpx;
  color: #999999;
}

.reward-right {
  flex: 1;
}

.reward-desc {
  font-size: 26rpx;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.reward-progress-bar {
  background: #eeeeee;
  border-radius: 8rpx;
  height: 12rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.reward-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f4a261, #e63946);
  border-radius: 8rpx;
}

.reward-progress-text {
  font-size: 22rpx;
  color: #999999;
}
