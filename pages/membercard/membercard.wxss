.container {
  background: #f0f0f0;
  min-height: 100vh;
  padding: 20rpx;
}

.member-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #e63946 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(230, 57, 70, 0.3);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 36rpx;
}

.gym-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.card-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.card-avatar-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.card-middle {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.card-member-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.card-belt {
  font-size: 26rpx;
  color: #f4a261;
  background: rgba(244, 162, 97, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
}

.card-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
}

.card-value {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.expire-days {
  color: #f4a261;
}

.stats-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.stat-num.red {
  color: #e63946;
}

.stat-num.green {
  color: #2d6a4f;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e0e0e0;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.pl-used {
  font-size: 24rpx;
  color: #666666;
}

.pl-remain {
  font-size: 24rpx;
  color: #2d6a4f;
  font-weight: bold;
}

.progress-bar-track {
  background: #e0e0e0;
  border-radius: 8rpx;
  height: 20rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #e63946, #f4a261);
  border-radius: 8rpx;
}

.progress-percent {
  font-size: 22rpx;
  color: #999999;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.benefit-item:last-child {
  border-bottom: none;
}

.benefit-icon {
  font-size: 28rpx;
}

.benefit-text {
  font-size: 28rpx;
  color: #333333;
}
