/* 会员卡购买详情页样式 */
.container {
  background: linear-gradient(160deg, #0d0d0d 0%, #1c1c1e 100%);
  min-height: 100vh;
}

.card-banner {
  background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
  border-bottom: 1rpx solid rgba(255, 45, 85, 0.3);
  padding: 40rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.card-banner::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 45, 85, 0.08);
}

.banner-badge {
  background: rgba(255, 45, 85, 0.2);
  border: 1rpx solid rgba(255, 45, 85, 0.4);
  border-radius: 8rpx;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: #ff2d55;
  margin-bottom: 16rpx;
}

.card-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.price-display {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.price-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #ff2d55;
  line-height: 1;
}

.price-unit {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 8rpx;
}

.highlight-text {
  font-size: 26rpx;
  color: #ffd60a;
  margin-bottom: 8rpx;
}

.monthly-avg {
  font-size: 24rpx;
  color: #8e8e93;
}

.detail-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin: 16rpx 20rpx 0;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #8e8e93;
}

.detail-value {
  font-size: 26rpx;
  color: #ffffff;
}

.detail-value.accent {
  color: #ff2d55;
  font-weight: bold;
}

.desc-text {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.6;
  display: block;
  margin-top: 12rpx;
}

.include-item, .benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.include-icon {
  font-size: 24rpx;
  color: #30d158;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.include-text {
  font-size: 26rpx;
  color: #ffffff;
  flex: 1;
}

.benefit-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.benefit-text {
  font-size: 26rpx;
  color: #ffd60a;
  flex: 1;
}

.suitable-text {
  font-size: 26rpx;
  color: #007aff;
}

.notice-text {
  font-size: 24rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(13, 13, 13, 0.96);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.total-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #8e8e93;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff2d55;
}

.buy-btn {
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  border-radius: 50rpx;
  height: 80rpx;
  padding: 0 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 45, 85, 0.4);
}

.buy-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8e8e93;
}
