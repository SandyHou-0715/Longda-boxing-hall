/* 登录页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a1a 0%, #2d0000 50%, #1a1a1a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

/* 顶部标题区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-circle {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #c0392b, #e74c3c);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(192, 57, 43, 0.5);
}

.logo-text {
  font-size: 70rpx;
  line-height: 1;
}

.app-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #f39c12;
  letter-spacing: 6rpx;
}

/* 表单卡片 */
.form-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 40rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 50rpx;
}

/* 输入框组 */
.input-group {
  margin-bottom: 36rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  padding: 0 24rpx;
  height: 96rpx;
  transition: border-color 0.2s;
}

.input-wrapper:focus-within {
  border-color: #c0392b;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  height: 96rpx;
  line-height: 96rpx;
}

.placeholder {
  color: #bbbbbb;
  font-size: 28rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(90deg, #c0392b, #e74c3c);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  border-radius: 50rpx;
  border: none;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(192, 57, 43, 0.4);
}

.login-btn::after {
  border: none;
}

/* 演示账号提示 */
.demo-hint {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(243, 156, 18, 0.3);
  margin-bottom: 40rpx;
}

.hint-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.hint-title {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: bold;
}

.hint-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.hint-label {
  font-size: 24rpx;
  color: #cccccc;
  width: 100rpx;
}

.hint-value {
  font-size: 24rpx;
  color: #ffffff;
}

.hint-accounts {
  margin-top: 8rpx;
}

.hint-sub {
  font-size: 22rpx;
  color: #aaaaaa;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding-top: 30rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}
