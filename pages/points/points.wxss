/* 积分页样式 */
.container {
  background: #f0f0f0;
  min-height: 100vh;
}

/* 顶部积分展示 */
.points-header {
  background: linear-gradient(160deg, #1a1a1a 0%, #4a1a00 100%);
  padding: 50rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-circle {
  width: 120rpx;
  height: 120rpx;
  background: rgba(243, 156, 18, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(243, 156, 18, 0.4);
}

.points-icon {
  font-size: 60rpx;
}

.points-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #f39c12;
  line-height: 1;
  margin-bottom: 8rpx;
}

.points-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.member-badge {
  background: rgba(243, 156, 18, 0.2);
  border: 1rpx solid rgba(243, 156, 18, 0.4);
  border-radius: 30rpx;
  padding: 8rpx 30rpx;
}

.member-text {
  font-size: 24rpx;
  color: #f39c12;
}

/* 快速统计 */
.quick-stats {
  background: #ffffff;
  margin: -20rpx 20rpx 0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.quick-stat-item {
  flex: 1;
  text-align: center;
}

.qs-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.qs-num.earn {
  color: #2e7d32;
}

.qs-num.spend {
  color: #c62828;
}

.qs-label {
  font-size: 22rpx;
  color: #999999;
}

.qs-divider {
  width: 1rpx;
  height: 50rpx;
  background: #e0e0e0;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  margin: 20rpx 20rpx 0;
  border-radius: 12rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #c0392b;
  color: #ffffff;
  font-weight: bold;
}

/* 列表容器 */
.list-container {
  padding: 16rpx 20rpx 0;
}

/* 积分记录条目 */
.history-item {
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.history-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: bold;
}

.earn-icon {
  background: #e8f5e9;
  color: #2e7d32;
}

.spend-icon {
  background: #fce4ec;
  color: #c62828;
}

.history-content {
  flex: 1;
}

.history-reason {
  font-size: 28rpx;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.history-date {
  font-size: 22rpx;
  color: #999999;
}

.history-right {
  text-align: right;
}

.history-amount {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 4rpx;
}

.earn-amount {
  color: #2e7d32;
}

.spend-amount {
  color: #c62828;
}

.history-balance {
  font-size: 20rpx;
  color: #bbbbbb;
}

/* 积分规则 */
.rules-section {
  padding-top: 4rpx;
}

.rule-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.rule-group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  padding: 24rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #f0f0f0;
  display: block;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.rule-item:last-child {
  border-bottom: none;
}

.earn-rule {
  border-left: 4rpx solid #2e7d32;
}

.spend-rule {
  border-left: 4rpx solid #c62828;
}

.rule-info {
  flex: 1;
}

.rule-event {
  font-size: 28rpx;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.rule-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

.rule-points {
  font-size: 30rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.earn-points {
  color: #2e7d32;
}

.spend-points {
  color: #c62828;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
