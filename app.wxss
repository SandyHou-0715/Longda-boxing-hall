/* 全局样式 - 龙达搏击馆 暗黑酷炫风 */
/* 主色: #ff2d55 (亮红) | #007aff (电光蓝) | #0d0d0d (深黑) */
/* 辅色: #5856d6 (渐变紫) | #30d158 (霓虹绿) | #ffd60a (金色) */

page {
  background-color: #0d0d0d;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 0;
  box-sizing: border-box;
}

/* 毛玻璃卡片 */
.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

/* 渐变色按钮 */
.btn-primary {
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 85, 0.4);
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  background: transparent;
  color: #ff2d55;
  border: 2rpx solid rgba(255, 45, 85, 0.5);
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 0;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-secondary::after {
  border: none;
}

/* 标题 */
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  padding: 30rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  color: #8e8e93;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8e8e93;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-beginner {
  background: rgba(48, 209, 88, 0.15);
  color: #30d158;
}

.tag-intermediate {
  background: rgba(255, 159, 10, 0.15);
  color: #ff9f0a;
}

.tag-advanced {
  background: rgba(255, 45, 85, 0.15);
  color: #ff2d55;
}

.tag-pending {
  background: rgba(0, 122, 255, 0.15);
  color: #007aff;
}

.tag-completed {
  background: rgba(48, 209, 88, 0.15);
  color: #30d158;
}

.tag-cancelled {
  background: rgba(142, 142, 147, 0.15);
  color: #8e8e93;
}

/* 进度条 */
.progress-bar-track {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  height: 16rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #ff2d55, #5856d6);
  transition: width 0.3s ease;
}
